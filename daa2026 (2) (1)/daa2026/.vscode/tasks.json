{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build-all-cpp",
      "type": "shell",
      "command": "g++",
      "args": [
        "-g",
        "-std=c++17",
        "main.cpp",
        "graph.cpp",
        "dijkstra.cpp",
        "astar.cpp",
        "utils.cpp",
        "-o",
        "build/Debug/outDebug.exe"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$gcc"
      ]
    }
  ]
}
